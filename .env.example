# ───────────────────────────────────────────────────────────────
# Variables d'environnement — Calli Recomp Tracker
# Copie ce fichier en `.env` (local) et en variables Vercel (prod).
# NE COMMITTE JAMAIS de clé privée dans le repo.
# ───────────────────────────────────────────────────────────────

# ── Supabase (clés PUBLIQUES, sûres à exposer côté client) ──
SUPABASE_URL="https://VOTRE_PROJET.supabase.co"
SUPABASE_PROJECT_ID="VOTRE_PROJET_ID"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
VITE_SUPABASE_URL="https://VOTRE_PROJET.supabase.co"
VITE_SUPABASE_PROJECT_ID="VOTRE_PROJET_ID"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# ── Web Push (clé PUBLIQUE VAPID, côté client) ──
VITE_VAPID_PUBLIC_KEY="BDRb..."

# ── SECRETS (uniquement sur Vercel / serveur, JAMAIS en client) ──
# Clé service role Supabase (bypass RLS — réservée au cron /api/cron-push)
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."
# Clé VAPID privée (associée à VITE_VAPID_PUBLIC_KEY)
VAPID_PRIVATE_KEY="..."
# Jeton secret du cron Vercel (header Authorization: Bearer <CRON_SECRET>)
CRON_SECRET="generer-une-chaine-aleatoire-longue"
