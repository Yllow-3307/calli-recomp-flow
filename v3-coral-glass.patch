+
+/* ============ Coral Glass : panel héros corail + bouteille d'eau ============ */
+
+@utility panel-coral {
+  background:
+    radial-gradient(circle at 85% 0%, rgba(255, 77, 141, 0.3), transparent 55%),
+    radial-gradient(circle at 0% 100%, rgba(255, 140, 60, 0.28), transparent 55%),
+    linear-gradient(
+      150deg,
+      rgba(255, 107, 74, 0.22),
+      rgba(255, 77, 141, 0.08) 60%,
+      rgba(255, 255, 255, 0.02)
+    );
+  border: 1px solid rgba(255, 120, 90, 0.28);
+  box-shadow: 0 14px 40px -12px rgba(255, 90, 80, 0.35);
+  backdrop-filter: blur(14px);
+  -webkit-backdrop-filter: blur(14px);
+  border-radius: var(--radius-2xl);
+  transition:
+    border-color 0.3s ease,
+    box-shadow 0.3s ease;
+}
+
+/* Vagues de la bouteille d'eau */
+@keyframes wb-sway {
+  from {
+    transform: translateX(0);
+  }
+  to {
+    transform: translateX(-60px);
+  }
+}
+
+.wb-wave {
+  animation: wb-sway 3.2s ease-in-out infinite alternate;
+  transform-box: fill-box;
+}
+
+.wb-wave-slow {
+  animation-duration: 5.6s;
+  animation-direction: alternate-reverse;
+}
